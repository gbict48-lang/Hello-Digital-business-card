default_platform(:ios)

BUNDLE_ID = "nl.gbict.hellodigitalbusinesscard"
PROJECT = "HelloDigitalBusinessCard.xcodeproj"
SCHEME = "HelloDigitalBusinessCard"

platform :ios do
  desc "Build the app and upload it to TestFlight"
  lane :beta do
    setup_ci

    team_id = ENV["APPLE_TEAM_ID"] || "476FB5QW34"
    key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"]
    issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"]
    key_path = ENV["AUTH_KEY_PATH"]   # absolute path to the .p8 written by CI

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_path,
      in_house: false
    )

    # Unique build number per CI run.
    increment_build_number(
      xcodeproj: PROJECT,
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s
    )

    # Automatic signing: -allowProvisioningUpdates lets Xcode create/download the
    # distribution certificate and App Store provisioning profile using the API
    # key — so no cert/profile secrets are needed.
    build_app(
      project: PROJECT,
      scheme: SCHEME,
      clean: true,
      export_method: "app-store",
      xcargs: [
        "-allowProvisioningUpdates",
        "-authenticationKeyID #{key_id}",
        "-authenticationKeyIssuerID #{issuer_id}",
        "-authenticationKeyPath #{key_path}"
      ].join(" "),
      export_options: {
        method: "app-store",
        signingStyle: "automatic",
        teamID: team_id
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false
    )
  end
end
