default_platform(:ios)

TEAM_ID = "476FB5QW34"
BUNDLE_ID = "nl.gbict.hellodigitalbusinesscard"
PROJECT = "HelloDigitalBusinessCard.xcodeproj"
SCHEME = "HelloDigitalBusinessCard"

platform :ios do
  desc "Build the app and upload it to TestFlight"
  lane :beta do
    # Creates a temporary keychain on CI and makes it the default.
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT_BASE64"],
      is_key_content_base64: true,
      in_house: false
    )

    profile_name = ENV["PROVISIONING_PROFILE_NAME"]

    # Use the CI run number as the build number so every upload is unique.
    increment_build_number(
      xcodeproj: PROJECT,
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s
    )

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      clean: true,
      export_method: "app-store",
      xcargs: [
        "CODE_SIGN_STYLE=Manual",
        "DEVELOPMENT_TEAM=#{TEAM_ID}",
        "CODE_SIGN_IDENTITY=Apple\\ Distribution",
        "PROVISIONING_PROFILE_SPECIFIER=#{profile_name}"
      ].join(" "),
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: TEAM_ID,
        provisioningProfiles: {
          BUNDLE_ID => profile_name
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false
    )
  end
end
